generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                         String   @id @default(cuid())
  username                   String   @unique
  xp                         Int      @default(0)
  streak                     Int      @default(0)
  lastLogin                  DateTime @default(now())
  completedLessons           String[] @default([])
  module1lessontour          Int      @default(0)
  module1practice            Int      @default(0)
  module2practice            Int      @default(0)
  playground                 Int      @default(0)
  onboardingVersionCompleted Int      @default(0)
}
